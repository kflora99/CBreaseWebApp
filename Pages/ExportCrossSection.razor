@page "/export-cross-section"
@using System.IO
@using Brease.Core.Models
@using CBreaseWebApp1.Services
@inject ProjectState ProjectState
@inject CbzFileService CbzService
@inject IJSRuntime JS

<h3>Export New Cross Section</h3>

@if (!string.IsNullOrWhiteSpace(StatusMessage))
{
    <div class="alert alert-info">@StatusMessage</div>
}

@if (!string.IsNullOrWhiteSpace(WarningMessage))
{
    <div class="alert alert-warning">
        <div>@WarningMessage</div>
        @if (!string.IsNullOrWhiteSpace(WarningDetails))
        {
            <pre class="mb-0 mt-2 small text-wrap">@WarningDetails</pre>
        }
    </div>
}

@if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <div class="alert alert-danger">
        <div>@ErrorMessage</div>
        @if (!string.IsNullOrWhiteSpace(ErrorDetails))
        {
            <pre class="mb-0 mt-2 small text-wrap">@ErrorDetails</pre>
        }
    </div>
}

<button class="btn btn-primary" @onclick="ExportUpdatedCbzAsync">
    Export Updated CBZ
</button>

@code {
    private string? StatusMessage;
    private string? WarningMessage;
    private string? WarningDetails;
    private string? ErrorMessage;
    private string? ErrorDetails;

    private async Task ExportUpdatedCbzAsync()
    {
        StatusMessage = null;
        WarningMessage = null;
        WarningDetails = null;
        ErrorMessage = null;
        ErrorDetails = null;

        try
        {
            var project = ProjectState.CurrentProject;
            var originalCbzText = ProjectState.OriginalCbzText;

            if (project is null)
            {
                ErrorMessage = "No CBZ project is loaded.";
                return;
            }

            if (string.IsNullOrWhiteSpace(originalCbzText))
            {
                ErrorMessage = "Original CBZ text is not available.";
                return;
            }

            string fileName;
            if (!string.IsNullOrWhiteSpace(ProjectState.OriginalCbzFileName))
            {
                fileName = Path.GetFileNameWithoutExtension(ProjectState.OriginalCbzFileName) + "_updated.cbz";
            }
            else if (!string.IsNullOrWhiteSpace(project.BridgeId))
            {
                fileName = $"{project.BridgeId}_updated.cbz";
            }
            else
            {
                fileName = "updated.cbz";
            }

            var validation = CbzService.ValidateExportText(originalCbzText, fileName);
            if (!validation.Succeeded)
            {
                ErrorMessage = validation.Message;
                ErrorDetails = validation.Details;
                return;
            }

            var saved = await JS.InvokeAsync<bool>(
                "saveFileFromText",
                fileName,
                "text/plain",
                originalCbzText);

            if (!saved)
            {
                await JS.InvokeVoidAsync(
                    "downloadFileFromText",
                    fileName,
                    "text/plain",
                    originalCbzText);
            }

            if (validation.HasWarnings)
            {
                WarningMessage = validation.Message;
                WarningDetails = validation.Details;
                StatusMessage = $"Exported {fileName}";
            }
            else
            {
                StatusMessage = $"{validation.Message} Exported {fileName}";
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
    }
}
