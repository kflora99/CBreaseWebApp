@using System.Collections.Generic
@using System.Linq
@using Brease.Core.Validation

@if (WarningList.Count > 0)
{
    <div class="alert alert-warning" role="alert">
        <strong>Cross-section Station/Elev. warnings:</strong>
        <ul class="mb-0">
            @foreach (var warning in WarningList.Take(5))
            {
                <li>@CbzCrossSectionStationElevationValidationFormatter.FormatIssue(warning)</li>
            }
        </ul>
        @if (WarningList.Count > 5)
        {
            <div>@CbzCrossSectionStationElevationValidationFormatter.FormatMoreLine(WarningList.Count - 5)</div>
        }
    </div>
}

@code {
    [Parameter]
    public IReadOnlyList<CbzCrossSectionStationElevationValidationResult>? Warnings { get; set; }

    private IReadOnlyList<CbzCrossSectionStationElevationValidationResult> WarningList =>
        Warnings ?? Array.Empty<CbzCrossSectionStationElevationValidationResult>();
}
